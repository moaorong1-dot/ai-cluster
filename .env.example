# 星轨智库环境变量模板
# 复制为 .env 并填入实际值

# 服务端口
BRAIN_PORT=8792
BRAIN_DEBUG=false

# DeepSeek LLM
DEEPSEEK_API_KEY=your-deepseek-api-key

# Milvus (复用 AI 集群已有实例)
MILVUS_URI=http://127.0.0.1:19530

# Redis (复用 AI 集群已有实例)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=Daren2026Redis!
REDIS_DB=2

# PostgreSQL (复用 AI 集群已有实例)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=cs_admin
PG_PASSWORD=cs_pg_2026_secret
PG_DATABASE=brain_db

# JWT
JWT_SECRET=change-me-to-a-strong-random-string
